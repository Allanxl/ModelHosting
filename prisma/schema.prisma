generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String              @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accounts           Account[]
  apiConfigs         ApiConfig[]         @relation("ApiConfigOwner")
  generationHistory  GenerationHistory[]
  permissions        Permission[]        @relation("PermissionGrantee")
  sessions           Session[]
  usageLogs          UsageLog[]
  verificationTokens VerificationToken[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String
  expires    DateTime
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([identifier, token])
}

model ApiConfig {
  id                String              @id @default(cuid())
  ownerId           String
  platformName      String
  baseUrl           String
  encryptedApiKey   String
  dailyVideoLimit   Int                 @default(50)
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  owner             User                @relation("ApiConfigOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  models            ApiModel[]
  generationHistory GenerationHistory[]
  inviteTokens      InviteToken[]
  permissions       Permission[]
  usageLogs         UsageLog[]
}

model ApiModel {
  id          String    @id @default(cuid())
  apiConfigId String
  modelId     String
  label       String
  createdAt   DateTime  @default(now())
  apiConfig   ApiConfig @relation(fields: [apiConfigId], references: [id], onDelete: Cascade)

  @@unique([apiConfigId, modelId])
}

model Permission {
  id          String     @id @default(cuid())
  apiConfigId String
  granteeId   String
  grantedAt   DateTime   @default(now())
  revokedAt   DateTime?
  isActive    Boolean    @default(true)
  apiConfig   ApiConfig  @relation(fields: [apiConfigId], references: [id], onDelete: Cascade)
  grantee     User       @relation("PermissionGrantee", fields: [granteeId], references: [id], onDelete: Cascade)
  usageLogs   UsageLog[]

  @@unique([apiConfigId, granteeId])
}

model InviteToken {
  id          String    @id @default(cuid())
  apiConfigId String
  token       String    @unique @default(cuid())
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  apiConfig   ApiConfig @relation(fields: [apiConfigId], references: [id], onDelete: Cascade)
}

model UsageLog {
  id           String      @id @default(cuid())
  userId       String
  apiConfigId  String
  permissionId String?
  modelId      String
  prompt       String?
  status       String      @default("success")
  createdAt    DateTime    @default(now())
  apiConfig    ApiConfig   @relation(fields: [apiConfigId], references: [id], onDelete: Cascade)
  permission   Permission? @relation(fields: [permissionId], references: [id])
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GenerationHistory {
  id          String    @id @default(cuid())
  userId      String
  apiConfigId String
  modelId     String
  prompt      String
  params      Json?
  resultUrl   String?
  resultData  Json?
  status      String    @default("pending")
  errorMsg    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  apiConfig   ApiConfig @relation(fields: [apiConfigId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
